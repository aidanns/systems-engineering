{
  "name": "systems-engineering-diagrams",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "postCreateCommand": "scripts/build.sh",
  "remoteEnv": {
    "ANTHROPIC_API_KEY": "${localEnv:ANTHROPIC_API_KEY}"
  },
  "mounts": [
    "source=${localEnv:HOME}/.claude/CLAUDE.md,target=/home/codespace/.claude/CLAUDE.md,type=bind,readonly",
    "source=${localEnv:HOME}/.claude/settings.json,target=/home/codespace/.claude/settings.json,type=bind,readonly",
    "source=${localEnv:HOME}/.gitconfig,target=/home/codespace/.gitconfig,type=bind,readonly",
    "source=${localEnv:HOME}/.ssh,target=/home/codespace/.ssh,type=bind,readonly"
  ]
}
