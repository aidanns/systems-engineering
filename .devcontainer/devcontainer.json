{
  "name": "systems-engineering-diagrams",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "postCreateCommand": "scripts/build.sh",
  // Optional: forward ANTHROPIC_API_KEY for Claude Code API key auth.
  // Not required if using OAuth login (claude login) inside the container.
  "remoteEnv": {
    "ANTHROPIC_API_KEY": "${localEnv:ANTHROPIC_API_KEY}"
  },
  // TODO(aidanns): Make bind mounts more portable so missing host files don't prevent startup.
  // Bind mounts for Claude Code and git configuration from the host.
  // Prerequisites: ~/.gitconfig, ~/.ssh, ~/.config/gh, ~/.claude/CLAUDE.md,
  // ~/.claude/settings.json, ~/.claude/.credentials.json, and ~/.claude.json
  // must exist on the host. Remove any lines for files you don't have.
  "mounts": [
    "source=${localEnv:HOME}/.claude/CLAUDE.md,target=/home/vscode/.claude/CLAUDE.md,type=bind,readonly",
    "source=${localEnv:HOME}/.claude/settings.json,target=/home/vscode/.claude/settings.json,type=bind,readonly",
    "source=${localEnv:HOME}/.gitconfig,target=/home/vscode/.gitconfig,type=bind,readonly",
    "source=${localEnv:HOME}/.ssh,target=/home/vscode/.ssh,type=bind,readonly",
    "source=${localEnv:HOME}/.config/gh,target=/home/vscode/.config/gh,type=bind,readonly",
    // Read-write: Claude Code writes auth/session state to these files.
    "source=${localEnv:HOME}/.claude.json,target=/home/vscode/.claude.json,type=bind",
    "source=${localEnv:HOME}/.claude/.credentials.json,target=/home/vscode/.claude/.credentials.json,type=bind"
  ]
}
