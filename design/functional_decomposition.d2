vars: {
  d2-config: {
    layout-engine: elk
    # Terminal theme code
    theme-id: 300
  }
}

direction: down

root: Systems Engineering CLI
root.width: 400

f0: Input Processing
f0.width: 400
root -> f0
f0_container: "" {
  grid-columns: 1
  grid-rows: 5
  grid-gap: 5
  style: {
    stroke-width: 0
    fill: transparent
  }
  f1: Load YAML
  f1.width: 400
  f2: Parse Functional Decomposition
  f2.width: 400
  f3: Parse Product Breakdown
  f3.width: 400
  f4: Find Subtree
  f4.width: 400
  f5: Filter Tree
  f5.width: 400
}
f0 -> f0_container

f6: Output Generation
f6.width: 400
root -> f6
f6_container: "" {
  grid-columns: 1
  grid-rows: 6
  grid-gap: 5
  style: {
    stroke-width: 0
    fill: transparent
  }
  f7: Generate Functional D2
  f7.width: 400
  f8: Generate Functional Markdown
  f8.width: 400
  f9: Generate Functional CSV
  f9.width: 400
  f10: Generate Product D2
  f10.width: 400
  f11: Generate Product Markdown
  f11.width: 400
  f12: Generate Product CSV
  f12.width: 400
}
f6 -> f6_container

f13: Rendering
f13.width: 400
root -> f13
f13_container: "" {
  grid-columns: 1
  grid-rows: 2
  grid-gap: 5
  style: {
    stroke-width: 0
    fill: transparent
  }
  f14: Render SVG
  f14.width: 400
  f15: Render PNG
  f15.width: 400
}
f13 -> f13_container

f16: Verification
f16.width: 400
root -> f16
f16_container: "" {
  grid-columns: 1
  grid-rows: 2
  grid-gap: 5
  style: {
    stroke-width: 0
    fill: transparent
  }
  f17: Verify Function Allocation
  f17.width: 400
  f18: Verify Function Test Coverage
  f18.width: 400
}
f16 -> f16_container

f19: CLI Interface
f19.width: 400
root -> f19
f19_container: "" {
  grid-columns: 1
  grid-rows: 2
  grid-gap: 5
  style: {
    stroke-width: 0
