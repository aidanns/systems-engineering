vars: {
  d2-config: {
    layout-engine: elk
    # Terminal theme code
    theme-id: 300
  }
}

direction: down

root: Systems Engineering CLI
root.width: 250

f0: Input Processing
f0.width: 250
root -> f0
f0_container: "" {
  grid-columns: 1
  grid-gap: 5
  style: {
    stroke-width: 0
    fill: transparent
  }
  f1: Load YAML
  f1.width: 250
  f2: Find Subtree
  f2.width: 250
  f3: Filter Tree
  f3.width: 250
}
f0 -> f0_container

f4: Output Generation
f4.width: 250
root -> f4
f4_container: "" {
  grid-columns: 1
  grid-gap: 5
  style: {
    stroke-width: 0
    fill: transparent
  }
  f5: Generate D2
  f5.width: 250
  f6: Generate Markdown
  f6.width: 250
  f7: Generate CSV
  f7.width: 250
}
f4 -> f4_container

f8: Rendering
f8.width: 250
root -> f8
f8_container: "" {
  grid-columns: 1
  grid-gap: 5
  style: {
    stroke-width: 0
    fill: transparent
  }
  f9: Render SVG
  f9.width: 250
  f10: Render PNG
  f10.width: 250
}
f8 -> f8_container

f11: CLI Interface
f11.width: 250
root -> f11
f11_container: "" {
  grid-columns: 1
  grid-gap: 5
  style: {
    stroke-width: 0
    fill: transparent
  }
  f12: Argument Parsing
  f12.width: 250
  f13: File Processing
  f13.width: 250
}
f11 -> f11_container
